/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    withName: FASTQC {
        ext.args = '--quiet'
        publishDir = [
            path: { "${params.outdir}/01-fq_trim" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: FASTP {
        publishDir = [
            path: { "${params.outdir}/01-fq_trim" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: TRIMMOMATIC {
        ext.args = { params.trimmomatic_args }
        publishDir = [
            path: { "${params.outdir}/01-fq_trim" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: BWA_INDEX {
        publishDir = [
            path: { "${params.outdir}/00-ref_gatk4" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: SAMTOOLS_FAIDX {
        publishDir = [
            path: { "${params.outdir}/00-ref_gatk4" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_CREATESEQUENCEDICTIONARY {
        publishDir = [
            path: { "${params.outdir}/00-ref_gatk4" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: BWA_MEM {
        ext.args = {
            "-K 10000000 -R '@RG\\tID:${meta.id}\\tSM:${meta.id}\\tLB:${meta.id}\\tPL:ILLUMINA\\tPU:${meta.id}'"
        }
        ext.prefix = { "${meta.id}_aln_sort" }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                filename.equals('versions.yml') ||
                (!['wgs', 'wes'].contains(params.sequencing_type) && params.known_sites && filename.endsWith('.bam'))
                    ? null
                    : filename
            }
        ]
    }

    withName: SAMTOOLS_INDEX {
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> params.known_sites ? null : filename }
        ]
    }

    withName: GATK4_MARKDUPLICATES {
        ext.args = '--CREATE_INDEX true'
        ext.prefix = { "${meta.id}_aln_sort_MD.bam" }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_BASERECALIBRATOR {
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD"
                : "${meta.id}_aln_sort"
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_APPLYBQSR {
        ext.args = '--create-output-bam-index true'
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD.tmp"
                : "${meta.id}_aln_sort.tmp"
        }
        ext.suffix = 'bam'
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: FINALIZE_CPU_BQSR_BAM {
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD"
                : "${meta.id}_aln_sort"
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withLabel: process_gpu {
        accelerator = params.gpu_count
        container = {
            workflow.containerEngine in ['singularity', 'apptainer'] && params.parabricks_sif
                ? params.parabricks_sif
                : 'nvcr.io/nvidia/clara/clara-parabricks:4.6.0-1'
        }
        containerOptions = {
            workflow.containerEngine in ['singularity', 'apptainer']
                ? '--nv'
                : workflow.containerEngine == 'docker'
                    ? '--gpus all'
                    : ''
        }
        errorStrategy = { params.gpu_fallback ? 'ignore' : 'terminate' }
        maxErrors = '-1'
        maxSubmitAwait = { params.gpu_max_submit_await }
    }

    withName: PARABRICKS_FQ2BAM {
        ext.args = {
            [
                "--read-group-id-prefix ${meta.id}",
                "--read-group-sm ${meta.id}",
                "--read-group-lb ${meta.id}",
                '--read-group-pl ILLUMINA',
                "--bwa-options='-K 10000000'",
                '--low-memory',
                ['wgs', 'wes'].contains(params.sequencing_type)
                    ? "--out-duplicate-metrics ${meta.id}.duplicate-metrics.txt"
                    : '--no-markdups'
            ].join(' ')
        }
        ext.prefix = {
            def final_prefix = ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD"
                : "${meta.id}_aln_sort"
            params.known_sites ? "${final_prefix}.prebqsr" : final_prefix
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: PARABRICKS_APPLYBQSR {
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD.tmp"
                : "${meta.id}_aln_sort.tmp"
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: FINALIZE_GPU_BQSR_BAM {
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD"
                : "${meta.id}_aln_sort"
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: SAMTOOLS_STATS {
        ext.prefix = {
            ['wgs', 'wes'].contains(params.sequencing_type)
                ? "${meta.id}_aln_sort_MD"
                : "${meta.id}_aln_sort"
        }
        publishDir = [
            path: { "${params.outdir}/02-bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_HAPLOTYPECALLER {
        ext.args = '--emit-ref-confidence GVCF --create-output-variant-index true'
        ext.prefix = { "${meta.id}.g" }
        publishDir = [
            path: { "${params.outdir}/03-sample_gvcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: PARABRICKS_HAPLOTYPECALLER {
        ext.args = '--gvcf'
        ext.prefix = { meta.id }
        publishDir = [
            path: { "${params.outdir}/03-sample_gvcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') || filename.equals('compatible_versions.yml') ? null : filename }
        ]
    }

    withName: PARABRICKS_INDEXGVCF {
        ext.prefix = { meta.id }
        publishDir = [
            path: { "${params.outdir}/03-sample_gvcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') || filename.equals('compatible_versions.yml') ? null : filename }
        ]
    }

    withName: CREATE_GVCF_SAMPLE_MAP {
        publishDir = [
            path: { "${params.outdir}/04-genomicsDB" },
            mode: params.publish_dir_mode,
            saveAs: { _filename -> null }
        ]
    }

    withName: GATK4_GENOMICSDBIMPORT {
        cpus = 4
        memory = 24.GB
        time = 12.h
        env.TILEDB_DISABLE_FILE_LOCKING = '1'
        ext.args = { "--batch-size 50 --reader-threads ${task.cpus}" }
        ext.prefix = { "${meta.id}.genomicsdb" }
        publishDir = [
            path: { "${params.outdir}/04-genomicsDB" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_GENOTYPEGVCFS {
        memory = 16.GB
        time = 12.h
        ext.args = { params.all_sites ? '--include-non-variant-sites true' : '' }
        ext.prefix = {
            params.all_sites
                ? "${meta.id}.all_sites.raw"
                : "${meta.id}.raw"
        }
        publishDir = [
            path: { "${params.outdir}/05-raw_vcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATK4_SELECTVARIANTS_FROM_GENOMICSDB {
        memory = 16.GB
        time = 12.h
        env.TILEDB_DISABLE_FILE_LOCKING = '1'
        ext.args = '--genomicsdb-shared-posixfs-optimizations true'
        ext.prefix = { "${meta.id}.subset" }
        publishDir = [
            path: { "${params.outdir}/05.1-subset" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: BCFTOOLS_VIEW {
        ext.args = {
            def filter_presets = [
                biallele: "-v snps -m2 -M2 -i 'F_MISSING < 0.1 && QUAL >= 30 && INFO/DP > 3'",
                monobi: "-m1 -M2 -i 'F_MISSING < 0.1 && INFO/DP > 3 && (TYPE=\"ref\" || (TYPE=\"snp\" && QUAL >= 30))'"
            ]
            def filter_args = params.bcftools_view_args != null
                ? params.bcftools_view_args
                : filter_presets[params.filter_vcf]
            "${filter_args ?: ''} --output-type z --write-index=tbi".trim()
        }
        ext.prefix = { "${meta.id}.filtered" }
        publishDir = [
            path: { "${params.outdir}/06-filtered_vcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATHER_RAW_VCFS {
        memory = 8.GB
        time = 6.h
        ext.prefix = 'all.raw'
        publishDir = [
            path: { "${params.outdir}/05-raw_vcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: GATHER_FILTERED_VCFS {
        memory = 8.GB
        time = 6.h
        ext.prefix = 'all.filtered'
        publishDir = [
            path: { "${params.outdir}/06-filtered_vcf" },
            mode: params.publish_dir_mode,
            overwrite: true,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
