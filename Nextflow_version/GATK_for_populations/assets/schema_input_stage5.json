{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 5 GenomicsDB input",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "contig": {
        "type": "string",
        "pattern": "^\\S+$",
        "meta": [
          "id"
        ]
      },
      "genomicsdb": {
        "type": "string",
        "format": "directory-path",
        "exists": true
      }
    },
    "required": [
      "contig",
      "genomicsdb"
    ]
  }
}
