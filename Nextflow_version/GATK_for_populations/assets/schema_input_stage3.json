{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Stage 3 BAM input",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "sample": {
        "type": "string",
        "pattern": "^\\S+$",
        "meta": [
          "id"
        ]
      },
      "bam": {
        "type": "string",
        "format": "file-path",
        "exists": true,
        "pattern": "^\\S+\\.bam$"
      },
      "bai": {
        "type": "string",
        "format": "file-path",
        "exists": true,
        "pattern": "^\\S+\\.(bam\\.)?bai$"
      }
    },
    "required": [
      "sample",
      "bam",
      "bai"
    ]
  }
}
