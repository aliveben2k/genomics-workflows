/*
 * nf-core/gatkpopulation per-process resource template
 *
 * Run with:
 *   ./run_pipeline.sh \
 *     -profile slurm,conda \
 *     -params-file analysis.yml \
 *     -c resources.config
 *
 * Copy this file to resources.config and tune it for the data and cluster.
 * Keep pipeline parameters in analysis.yml; use this file for process
 * resources and scheduler directives only.
 */

process {

    /*
     * Stage 0: reference preparation
     */
    withName: BWA_INDEX {
        cpus   = 12
        memory = 32.GB
        time   = 8.h
        // queue = 'long'
    }

    withName: SAMTOOLS_FAIDX {
        cpus   = 2
        memory = 4.GB
        time   = 1.h
    }

    withName: GATK4_CREATESEQUENCEDICTIONARY {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    /*
     * Stage 1: trimming and read QC
     */
    withName: FASTP {
        cpus   = 8
        memory = 16.GB
        time   = 4.h
    }

    withName: TRIMMOMATIC {
        cpus   = 8
        memory = 16.GB
        time   = 6.h
    }

    withName: FASTQC {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }

    /*
     * Stage 2: CPU BAM preprocessing
     */
    withName: BWA_MEM {
        cpus   = 16
        memory = 32.GB
        time   = 12.h
    }

    withName: SAMTOOLS_INDEX {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }

    withName: GATK4_MARKDUPLICATES {
        cpus   = 8
        memory = 32.GB
        time   = 12.h
    }

    withName: GATK4_BASERECALIBRATOR {
        cpus   = 8
        memory = 24.GB
        time   = 12.h
    }

    withName: GATK4_APPLYBQSR {
        cpus   = 8
        memory = 24.GB
        time   = 12.h
    }

    withName: FINALIZE_CPU_BQSR_BAM {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    withName: SAMTOOLS_STATS {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }

    /*
     * Stage 2: GPU BAM preprocessing
     *
     * GPU count is controlled by gpu_count in analysis.yml. For SGE/PBS,
     * configure the site-specific *_gpu_cluster_options parameter there.
     */
    withName: PARABRICKS_FQ2BAM {
        cpus   = 24
        memory = 64.GB
        time   = 12.h
        // queue = 'gpu'
    }

    withName: PARABRICKS_APPLYBQSR {
        cpus   = 8
        memory = 32.GB
        time   = 8.h
    }

    withName: FINALIZE_GPU_BQSR_BAM {
        cpus   = 2
        memory = 8.GB
        time   = 2.h
    }

    /*
     * Stage 3: per-sample GVCFs
     */
    withName: GATK4_HAPLOTYPECALLER {
        cpus   = 8
        memory = 24.GB
        time   = 24.h
    }

    withName: PARABRICKS_HAPLOTYPECALLER {
        cpus   = 16
        memory = 32.GB
        time   = 12.h
        // queue = 'gpu'
    }

    withName: PARABRICKS_INDEXGVCF {
        cpus   = 4
        memory = 8.GB
        time   = 4.h
    }

    /*
     * Stage 4: GenomicsDB
     */
    withName: CREATE_GVCF_SAMPLE_MAP {
        cpus   = 1
        memory = 2.GB
        time   = 1.h
    }

    withName: GATK4_GENOMICSDBIMPORT {
        cpus   = 8
        memory = 48.GB
        time   = 24.h
        // queue = 'long'
    }

    /*
     * Stage 5: subset selection and joint genotyping
     */
    withName: CREATE_SUBSET_SAMPLE_ARGS {
        cpus   = 1
        memory = 2.GB
        time   = 1.h
    }

    withName: GATK4_SELECTVARIANTS_FROM_GENOMICSDB {
        cpus   = 4
        memory = 24.GB
        time   = 12.h
    }

    withName: GATK4_GENOTYPEGVCFS {
        cpus   = 4
        memory = 24.GB
        time   = 24.h
    }

    withName: GATHER_RAW_VCFS {
        cpus   = 4
        memory = 16.GB
        time   = 12.h
    }

    /*
     * Stage 6: VCF filtering and optional gathering
     */
    withName: BCFTOOLS_VIEW {
        cpus   = 4
        memory = 8.GB
        time   = 6.h
    }

    withName: GATHER_FILTERED_VCFS {
        cpus   = 4
        memory = 16.GB
        time   = 12.h
    }

    /*
     * Reporting
     */
    withName: MULTIQC {
        cpus   = 2
        memory = 8.GB
        time   = 4.h
    }
}
