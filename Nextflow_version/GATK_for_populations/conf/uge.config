/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Generic Univa Grid Engine executor profile
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow runs UGE through its SGE-compatible executor.
    Combine with a software profile, for example:
      -profile uge,conda
      -profile uge,singularity
----------------------------------------------------------------------------------------
*/

process {
    executor = 'sge'
    queue = params.uge_queue
    penv = params.uge_penv
    clusterOptions = [
        params.uge_project ? "-P ${params.uge_project}" : '',
        params.uge_cluster_options ?: ''
    ].findAll { it }.join(' ')

    withLabel:process_gpu {
        clusterOptions = [
            params.uge_project ? "-P ${params.uge_project}" : '',
            params.uge_cluster_options ?: '',
            params.uge_gpu_cluster_options
                ? params.uge_gpu_cluster_options.replace('{gpu_count}', params.gpu_count.toString())
                : ''
        ].findAll { it }.join(' ')
    }
}

executor {
    queueSize = params.uge_queue_size
}
